# Server port (optional; default 3847)
# PORT=3847

# --- Ask: web snippet fetch (optional overrides)
# WEB_TIMEOUT_MS=12000
# WEB_MAX_RESULTS=4
# WEB_MAX_PAGES=3
# WEB_SNIPPET_CHARS=1400

# --- News crawl timeouts and caps (optional)
# NEWS_CRAWL_TIMEOUT_MS=75000
# NEWS_REFRESH_TIMEOUT_MS=120000
# NEWS_MERGE_CAP=520

# Optional: LLM APIs for summaries. Answers are grounded in the regulation text to avoid hallucination.
# Try order when no LLM_PROVIDER is set: Anthropic (best) → OpenAI → Gemini → Groq → Mistral → OpenRouter.
# To use only one provider: LLM_PROVIDER=openai | anthropic | gemini | groq | mistral | openrouter

# --- OpenAI
# https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini

# --- Anthropic (Claude)
# https://console.anthropic.com/
# ANTHROPIC_API_KEY=your-key-here
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --- Google Gemini
# https://aistudio.google.com/app/apikey
# GOOGLE_GEMINI_API_KEY=your-key-here
# GOOGLE_GEMINI_MODEL=gemini-1.5-flash

# --- Groq (fast inference, Llama/Mixtral) — primary Ask LLM
# https://console.groq.com/keys
# GROQ_API_KEY=your-key-here
# GROQ_MODEL=llama-3.1-70b-versatile

# --- Tavily — optional fallback when Groq fails (search + LLM answer)
# https://tavily.com/ — API keys in dashboard
# TAVILY_API_KEY=tvly-your-key-here
# TAVILY_SEARCH_DEPTH=advanced
# TAVILY_INCLUDE_ANSWER=advanced
# TAVILY_MAX_RESULTS=6
# Optional comma-separated domains to bias results (e.g. eur-lex.europa.eu,gdpr-info.eu)
# TAVILY_INCLUDE_DOMAINS=

# --- Mistral
# https://console.mistral.ai/api-keys/
# MISTRAL_API_KEY=your-key-here
# MISTRAL_MODEL=mistral-small-latest

# --- OpenRouter (one API for many models: Claude, GPT-4, Gemini, etc.)
# https://openrouter.ai/keys
# OPENROUTER_API_KEY=your-key-here
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# --- Optional: force a single provider
# LLM_PROVIDER=openai
# LLM_PROVIDER=anthropic
# LLM_PROVIDER=gemini
# LLM_PROVIDER=groq
# LLM_PROVIDER=mistral
# LLM_PROVIDER=openrouter
