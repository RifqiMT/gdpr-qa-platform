# Server port (optional; default 3847)
# PORT=3847
# Bind address (optional; default 0.0.0.0 — use 127.0.0.1 on shared laptops)
# HOST=0.0.0.0

# --- Vercel production (see docs/VERCEL_DEPLOY.md)
# Set in Vercel Project → Settings → Environment Variables (never commit real values).
# CRON_SECRET=generate-a-long-random-string-for-vercel-cron
# Optional writable data path (default on Vercel: /tmp/gdpr-qa-data, seeded from bundled data/)
# GDPR_DATA_DIR=/tmp/gdpr-qa-data

# --- Regulation ETL (Refresh sources)
# Primary corpus: gdpr-info = same layout as https://gdpr-info.eu/art-N-gdpr/ (default).
# eur-lex = official consolidated text from EUR-Lex (different paragraph whitespace).
# GDPR_ETL_PRIMARY=gdpr-info
# GDPR_ETL_PRIMARY=eur-lex
# Minimum counts when using GDPR-Info as primary (default 99 / 173 = full Regulation):
# MIN_GDPR_INFO_ARTICLES=99
# MIN_GDPR_INFO_RECITALS=173
# Optional: max characters per article/recital body in JSON (omit or high = no practical cap).
# GDPR_MAX_ARTICLE_CHARS=500000
# Parallel fetches when pulling GDPR-Info pages (default 6).
# GDPR_INFO_CONCURRENCY=6
# Force writing gdpr-content.json on next refresh even if hashes match (recovery / testing).
# GDPR_FORCE_CORPUS_WRITE=1
# Same as GDPR_FORCE_CORPUS_WRITE for operators who prefer this name:
# GDPR_FORCE_RELOAD_CORPUS=1

# --- EU AI Act ETL (Refresh sources when regulation = ai-act, or npm run refresh-ai-act)
# MIN_AI_ACT_ARTICLES=113
# MIN_AI_ACT_RECITALS=180
# AI_ACT_MAX_ARTICLE_CHARS=500000
# AI_ACT_INFO_CONCURRENCY=6
# AI_ACT_FORCE_CORPUS_WRITE=1

# --- EU Data Act ETL (Refresh sources when regulation = data-act, or npm run refresh-data-act)
# MIN_DATA_ACT_ARTICLES=50
# MIN_DATA_ACT_RECITALS=119
# DATA_ACT_MAX_ARTICLE_CHARS=500000
# DATA_ACT_INFO_CONCURRENCY=6
# DATA_ACT_FORCE_CORPUS_WRITE=1

# --- Ask: web snippet fetch (optional overrides)
# WEB_TIMEOUT_MS=12000
# WEB_MAX_RESULTS=4
# WEB_MAX_PAGES=3
# WEB_SNIPPET_CHARS=1400

# --- News crawl timeouts and caps (optional)
# Live merge on GET /api/news?live=1 only (default list is read from data/gdpr-news.json).
# NEWS_CRAWL_TIMEOUT_MS=90000
# POST /api/news/refresh (Refresh all sources) — allow time for ICO + all regulators.
# NEWS_REFRESH_TIMEOUT_MS=180000
# Max items returned after merge/dedupe (default 6000). Stored JSON can hold more; see server store cap.
# NEWS_MERGE_CAP=6000
# Crawler depth (optional — raise for more articles; longer refresh).
# NEWS_MAX_EDPB_PAGES=56
# NEWS_MAX_ICO_SEARCH_PAGES=44
# NEWS_MAX_ICO_SITEMAP_FETCHES=280
# NEWS_MAX_HTML_LINKS_PER_SOURCE=480
# NEWS_COMMISSION_RSS_CONCURRENCY=6
# NEWS_COMMISSION_RSS_PAGE_SIZE=100
# Cache for “Attachments” scan of article HTML (ms). Default 15 minutes.
# NEWS_ATTACHMENTS_CACHE_TTL_MS=900000
# NEWS_ATTACHMENTS_CACHE_MAX=150

# --- Groq (fast inference, Llama/Mixtral) — primary Ask LLM and chapter-summary regeneration
# https://console.groq.com/keys
# GROQ_API_KEY=your-key-here
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Tavily — optional fallback when Groq fails (search + LLM answer)
# https://tavily.com/ — API keys in dashboard
# TAVILY_API_KEY=tvly-your-key-here
# TAVILY_SEARCH_DEPTH=advanced
# TAVILY_INCLUDE_ANSWER=advanced
# TAVILY_MAX_RESULTS=6
# Optional comma-separated domains to bias results (e.g. eur-lex.europa.eu,gdpr-info.eu,ai-act-law.eu)
# TAVILY_INCLUDE_DOMAINS=

# --- News (additional knobs used by news-crawler.js)
# NEWS_FROM_YEAR=2015
# NEWS_TOPIC_ENRICH_ENABLE=1
# NEWS_TOPIC_ENRICH_MAX_TOPICS=36
# NEWS_TOPIC_ENRICH_TARGET_PER_TOPIC=10
# NEWS_TOPIC_ENRICH_CONCURRENCY=4
# NEWS_TOPIC_ENRICH_MAX_QUERIES=220
# NEWS_COMMISSION_RSS_MAX_PAGES=12
