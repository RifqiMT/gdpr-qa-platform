{
  "name": "gdpr-qa-platform",
  "version": "1.2.3",
  "description": "EU Regulation Q&A Platform — GDPR, EU AI Act, and EU Data Act; Browse, Ask (BM25 + Groq/Tavily), BYOK, news, credible sources; Vercel-ready",
  "main": "server.js",
  "scripts": {
    "prestart": "node -e \"const fs=require('fs'),p=require('path');const a=p.join('data','article-suitable-recitals.json'),b=p.join('public','article-suitable-recitals.json');try{if(fs.existsSync(a))fs.copyFileSync(a,b);}catch(e){}\"",
    "vercel-build": "npm run prestart",
    "start": "node server.js",
    "refresh": "node server.js --refresh-only",
    "refresh-ai-act": "node ai-act-scraper.js",
    "refresh-data-act": "node data-act-scraper.js",
    "fetch-suitable-recitals": "node scripts/fetch-article-suitable-recitals.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "node-cron": "^3.0.3"
  }
}
